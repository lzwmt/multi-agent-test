{
  "name": "RAG 工作机制 (Retrieval-Augmented Generation)",
  "children": [
    {
      "name": "核心概念",
      "children": [
        {
          "name": "定义: 检索增强生成"
        },
        {
          "name": "目标: 构建高质量知识库/智能客服"
        },
        {
          "name": "解决问题: 模型幻觉、上下文窗口限制、推理成本高"
        }
      ]
    },
    {
      "name": "提问前：数据准备阶段",
      "children": [
        {
          "name": "分片 (Chunking)",
          "children": [
            {
              "name": "按字数、段落、章节或页码切分"
            }
          ]
        },
        {
          "name": "索引 (Indexing)",
          "children": [
            {
              "name": "Embedding: 文本转向量"
            },
            {
              "name": "存储: 原始文本与向量存入向量数据库"
            }
          ]
        }
      ]
    },
    {
      "name": "提问后：回答阶段",
      "children": [
        {
          "name": "召回 (Retrieval)",
          "children": [
            {
              "name": "过程: 问题向量化并在数据库搜索"
            },
            {
              "name": "数量: 初筛前 N 个相似片段 (如10个)"
            },
            {
              "name": "计算: 余弦相似度、欧式距离、点积"
            },
            {
              "name": "特点: 成本低、速度快、准确率较低"
            }
          ]
        },
        {
          "name": "重排 (Rerank)",
          "children": [
            {
              "name": "模型: 使用 Cross-Encoder"
            },
            {
              "name": "功能: 从召回片段中精选最相关片段 (如3个)"
            },
            {
              "name": "特点: 准确率高、成本较高、耗时长"
            }
          ]
        },
        {
          "name": "生成 (Generation)",
          "children": [
            {
              "name": "组合: 用户问题 + 精选片段"
            },
            {
              "name": "输出: 大模型基于上下文产生最终答案"
            }
          ]
        }
      ]
    },
    {
      "name": "技术专有名词",
      "children": [
        {
          "name": "向量 (Vector): 数值数组，维度越大信息越丰富"
        },
        {
          "name": "Embedding 模型: 专门负责语义向量化的模型"
        },
        {
          "name": "向量数据库: 存储向量并提供相似度计算函数"
        },
        {
          "name": "上下文窗口: 模型单次处理信息的上限"
        }
      ]
    }
  ]
}